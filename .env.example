# Core app settings
APP_PORT=5000
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXP_SECONDS=86400

# Reverse proxy settings
# Example: https://accounta.example.com
CORS_ORIGINS=https://accounta.example.com
TRUST_PROXY_COUNT=1

# Runtime tuning
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Registration policy
# Leave true for first bootstrap, then set false after creating and promoting your admin user.
ALLOW_REGISTRATION=true

# SQLite-first production path
DATABASE_URL=sqlite:////app/data/accounta.db
